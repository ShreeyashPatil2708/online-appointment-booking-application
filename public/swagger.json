{
  "openapi": "3.0.0",
  "info": {
    "title": "Online Appointment Booking API",
    "version": "1.0.0",
    "description": "RESTful API for the Online Appointment Booking Application"
  },
  "servers": [
    {
      "url": "/api",
      "description": "API Base URL"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "role": { "type": "string", "enum": ["customer", "service_provider", "admin"] },
          "phone": { "type": "string" },
          "isActive": { "type": "boolean" },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "ServiceProvider": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "userId": { "type": "string" },
          "name": { "type": "string" },
          "email": { "type": "string" },
          "specialty": { "type": "string" },
          "services": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": { "type": "string" },
                "name": { "type": "string" },
                "duration": { "type": "number" },
                "price": { "type": "number" }
              }
            }
          },
          "rating": { "type": "number" },
          "totalReviews": { "type": "number" }
        }
      },
      "Appointment": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "userId": { "type": "string" },
          "serviceProviderId": { "type": "string" },
          "timeSlotId": { "type": "string" },
          "date": { "type": "string" },
          "startTime": { "type": "string" },
          "endTime": { "type": "string" },
          "status": { "type": "string", "enum": ["pending", "confirmed", "completed", "cancelled", "rejected"] },
          "notes": { "type": "string" }
        }
      },
      "TimeSlot": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "serviceProviderId": { "type": "string" },
          "date": { "type": "string" },
          "startTime": { "type": "string" },
          "endTime": { "type": "string" },
          "status": { "type": "string", "enum": ["available", "booked", "blocked"] }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "message": { "type": "string" }
        }
      }
    }
  },
  "paths": {
    "/auth/register": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Register a new user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "email", "password"],
                "properties": {
                  "name": { "type": "string" },
                  "email": { "type": "string" },
                  "password": { "type": "string", "minLength": 6 },
                  "role": { "type": "string", "enum": ["customer", "service_provider"] },
                  "phone": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "User registered successfully" },
          "400": { "description": "Validation error" },
          "409": { "description": "Email already registered" }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Login with email and password",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Login successful" },
          "401": { "description": "Invalid credentials" }
        }
      }
    },
    "/auth/refresh": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Refresh access token",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["refreshToken"],
                "properties": {
                  "refreshToken": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "New access token" },
          "401": { "description": "Invalid refresh token" }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Logout user",
        "responses": {
          "200": { "description": "Logged out successfully" }
        }
      }
    },
    "/auth/me": {
      "get": {
        "tags": ["Authentication"],
        "summary": "Get current user",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Current user data" },
          "401": { "description": "Not authenticated" }
        }
      }
    },
    "/appointments": {
      "post": {
        "tags": ["Appointments"],
        "summary": "Book an appointment",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["serviceProviderId", "timeSlotId"],
                "properties": {
                  "serviceProviderId": { "type": "string" },
                  "timeSlotId": { "type": "string" },
                  "serviceId": { "type": "string" },
                  "notes": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Appointment booked" },
          "409": { "description": "Time slot not available" }
        }
      }
    },
    "/appointments/my": {
      "get": {
        "tags": ["Appointments"],
        "summary": "Get my appointments",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "List of appointments" }
        }
      }
    },
    "/providers": {
      "get": {
        "tags": ["Service Providers"],
        "summary": "Get all service providers",
        "parameters": [
          { "name": "specialty", "in": "query", "schema": { "type": "string" } },
          { "name": "page", "in": "query", "schema": { "type": "integer" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "List of service providers" }
        }
      }
    },
    "/providers/{id}/slots": {
      "get": {
        "tags": ["Service Providers"],
        "summary": "Get available time slots for a provider",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "date", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "List of time slots" }
        }
      }
    },
    "/admin/stats": {
      "get": {
        "tags": ["Admin"],
        "summary": "Get system statistics",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "System statistics" }
        }
      }
    }
  }
}
